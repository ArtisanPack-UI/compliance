{
  "name": "artisanpack-ui/compliance",
  "description": "Compliance toolkit for Laravel — GDPR / CCPA / LGPD consent management, data subject rights (erasure + portability), DPIA / processing-activity records, data minimization (anonymization + pseudonymization), retention policies, compliance monitoring + reporting.",
  "type": "library",
  "license": "MIT",
  "version": "1.0.1",
  "keywords": [
    "laravel",
    "compliance",
    "gdpr",
    "ccpa",
    "lgpd",
    "consent",
    "privacy",
    "dpia",
    "data-subject-rights",
    "data-minimization"
  ],
  "autoload": {
    "psr-4": {
      "ArtisanPackUI\\Compliance\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Jacob Martella",
      "email": "support@artisanpackui.dev"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "artisanpack-ui/core": "^1.0"
  },
  "require-dev": {
    "artisanpack-ui/code-style": "^1.1",
    "artisanpack-ui/code-style-pint": "^1.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.75",
    "laravel/pint": "^1.26",
    "orchestra/testbench": "^10.2|^11.0",
    "pestphp/pest": "^3.8|^4.0",
    "pestphp/pest-plugin-laravel": "^3.2|^4.0"
  },
  "scripts": {
    "lint": [
      "./vendor/bin/php-cs-fixer fix --dry-run --diff",
      "./vendor/bin/phpcs"
    ],
    "fix": "./vendor/bin/php-cs-fixer fix",
    "cs": "./vendor/bin/phpcs",
    "cs:fix": "./vendor/bin/phpcbf",
    "test": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.2"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ArtisanPackUI\\Compliance\\ComplianceServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
